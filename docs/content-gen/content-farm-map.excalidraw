e": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 2}, "seed": 739803774, "version": 1, "versionNonce": 2093277617, "isDeleted": false, "boundElements": [], "updated": 1781257939290, "link": null, "locked": false, "points": [[0, 0], [0.0, 19.0]], "lastCommittedPoint": null, "startBinding": {"elementId": "x754eyBsu4zwyDiE", "focus": 0, "gap": 5}, "endBinding": {"elementId": "gnyyhwkdf10EFA4k", "focus": 0, "gap": 5}, "startArrowhead": null, "endArrowhead": "arrow"}, {"id": "Des8tmlv5hCjvks0", "type": "rectangle", "x": 420, "y": 6606, "width": 500, "height": 138, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "#ffd8a8", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 1487534111, "version": 1, "versionNonce": 1410579767, "isDeleted": false, "boundElements": [{"id": "jjmexusrkCtv9tB7", "type": "text"}, {"id": "apDnob7ADdhfke7v", "type": "arrow"}, {"id": "uAAdy47wikfuxbEw", "type": "arrow"}, {"id": "wt9ndjd1y9tsj0aa", "type": "arrow"}], "updated": 1781257939290, "link": null, "locked": false}, {"id": "jjmexusrkCtv9tB7", "type": "text", "x": 428, "y": 6614, "width": 484, "height": 122, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 145328231, "version": 1, "versionNonce": 346343134, "isDeleted": false, "boundElements": [], "updated": 1781257939290, "link": null, "locked": false, "text": "The whole script is read ONCE by the AI voice \u2014\nit flows like a person talking. We get back the\nexact moment every word is spoken, then slice\nthe recording per beat at word boundaries.\nSlightly sped up to genre pace (~167 wpm).", "fontSize": 15, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "containerId": "Des8tmlv5hCjvks0", "originalText": "The whole script is read ONCE by the AI voice \u2014\nit flows like a person talking. We get back the\nexact moment every word is spoken, then slice\nthe recording per beat at word boundaries.\nSlightly sped up to genre pace (~167 wpm).", "lineHeight": 1.25}, {"id": "4cn41mmkFn8obfxw", "type": "ellipse", "x": 1010, "y": 6606, "width": 320, "height": 109, "angle": 0, "strokeColor": "#6741d9", "backgroundColor": "#d0bfff", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 361095694, "version": 1, "versionNonce": 879715342, "isDeleted": false, "boundElements": [{"id": "hi7mt8CAjt4e5s0s", "type": "text"}, {"id": "uAAdy47wikfuxbEw", "type": "arrow"}], "updated": 1781257939290, "link": null, "locked": false}, {"id": "hi7mt8CAjt4e5s0s", "type": "text", "x": 1018, "y": 6614, "width": 304, "height": 93, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 681044474, "version": 1, "versionNonce": 1192041794, "isDeleted": false, "boundElements": [], "updated": 1781257939290, "link": null, "locked": false, "text": "ElevenLabs voice\nreturns audio +\nword timings", "fontSize": 14, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "containerId": "4cn41mmkFn8obfxw", "originalText": "ElevenLabs voice\nreturns audio +\nword timings", "lineHeight": 1.25}, {"id": "apDnob7ADdhfke7v", "type": "arrow", "x": 670.0, "y": 6585.0, "width": 0.0, "height": 16.0, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 2}, "seed": 215130971, "version": 1, "versionNonc