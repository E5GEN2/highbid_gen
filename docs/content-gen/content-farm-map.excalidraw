   "updated": 1781255606152,
   "link": null,
   "locked": false,
   "text": "Every beat becomes a short clip: visual + its slice\nof voice + a whoosh or ding + background music.\nAll clips are glued in order into the final video.\n(Anything built once \u2014 screenshots, cards, voice \u2014\nis cached and reused on the next render.)",
   "fontSize": 15,
   "fontFamily": 1,
   "textAlign": "center",
   "verticalAlign": "middle",
   "containerId": "jnq24ovlpFDqC7Aq",
   "originalText": "Every beat becomes a short clip: visual + its slice\nof voice + a whoosh or ding + background music.\nAll clips are glued in order into the final video.\n(Anything built once \u2014 screenshots, cards, voice \u2014\nis cached and reused on the next render.)",
   "lineHeight": 1.25
  },
