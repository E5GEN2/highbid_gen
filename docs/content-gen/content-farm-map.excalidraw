   "boundElements": [],
   "updated": 1781255606152,
   "link": null,
   "locked": false,
   "text": "BEAT 22 \u00b7 \"it's not a fluke\" \u2014 the format twin\nSEE (3 quick shots):\n\u2460 their name card \u2014 name, handle, subscriber +\nvideo counts ON SCREEN (voice never reads them)\n\u2461 their channel page \u2014 a wall of same-style videos\n\u2462 their best video card \u2014 held in silence for a\nbeat so the number sinks in\nVOICE: \"There is another channel that makes the\nsame kind of videos \u2014 it started posting only five\nmonths ago, and their most popular video has\nmore than 600 thousand views.\"",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "center",
   "verticalAlign": "middle",
   "containerId": "sp2Adlbk8herwb9t",
   "originalText": "BEAT 22 \u00b7 \"it's not a fluke\" \u2014 the format twin\nSEE (3 quick shots):\n\u2460 their name card \u2014 name, handle, subscriber +\nvideo counts ON SCREEN (voice never reads them)\n\u2461 their channel page \u2014 a wall of same-style videos\n\u2462 their best video card \u2014 held in silence for a\nbeat so the number sinks in\nVOICE: \"There is another channel that makes the\nsame kind of videos \u2014 it started posting only five\nmonths ago, and their most popular video has\nmore than 600 thousand views.\"",
   "lineHeight": 1.25
  },
